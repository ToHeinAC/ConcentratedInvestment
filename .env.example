# Copy to .env (gitignored) and fill in, or set these in Railway's "Variables" tab.
# Never commit real secrets.

# --- Email-on-trigger (Resend transactional email API) ---
# Create a free key at https://resend.com (3k emails/mo free). Used by `concinvest notify`.
RESEND_API_KEY=
# Where alerts are sent (your inbox).
ALERT_EMAIL_TO=tobias.hein@hotmail.de
# Verified sender. Resend's shared sandbox sender works out of the box; for a custom
# domain verify it in Resend first, e.g. "ConcInvest <alerts@yourdomain.de>".
ALERT_EMAIL_FROM=ConcInvest <onboarding@resend.dev>

# Which saved portfolio (data/portfolios/<name>.csv) the daily cron scores for triggers.
# Unset -> the daily_update.sh notify step is skipped.
ALERT_PORTFOLIO=
